{
  "name": "elysia-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Elysia 后端服务（Fastify + PostgreSQL + Redis + R2）",
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx scripts/migrate.ts",
    "worker": "tsx src/workers/index.ts",
    "worker:start": "node dist/src/workers/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "@aws-sdk/s3-request-presigner": "^3.888.0",
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.3.1",
    "@fastify/swagger-ui": "^5.2.2",
    "@fastify/websocket": "^11.2.0",
    "bullmq": "^5.58.5",
    "dotenv": "^16.6.1",
    "fastify": "^5.6.1",
    "ioredis": "^5.8.1",
    "openid-client": "^5.7.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.16.3",
    "pino": "^9.9.5",
    "ulid": "^3.0.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^22.18.1",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
