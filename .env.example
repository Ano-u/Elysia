NODE_ENV=development
PORT=3000
HOST=0.0.0.0

DATABASE_URL=postgres://postgres:postgres@localhost:5432/elysia
REDIS_URL=redis://localhost:6379

COOKIE_SECRET=replace_me_with_secure_cookie_secret
JWT_SECRET=replace_me_with_secure_jwt_secret
CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:3000,http://localhost:3000
ACCESS_GATE_BYPASS=auto
ONBOARDING_FORCE_SHOW=auto

R2_ENDPOINT=https://example.r2.cloudflarestorage.com
R2_BUCKET=elysia-media
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
R2_PUBLIC_BASE_URL=https://cdn.example.com
R2_STRICT_HEAD_CHECK=true

OIDC_ISSUER=https://wiki.linux.do
OIDC_CLIENT_ID=replace_me
OIDC_CLIENT_SECRET=replace_me
OIDC_REDIRECT_URI=https://api.example.com/auth/oidc/callback
OIDC_POST_LOGIN_REDIRECT=https://app.example.com/
OIDC_SCOPE=openid profile

CLOUDFLARE_TURNSTILE_SITE_KEY=replace_me
CLOUDFLARE_TURNSTILE_SECRET=replace_me

ANALYSIS_ENABLED=true
ANALYSIS_CLUSTERING_ENABLED=true
ANALYZER_URL=http://127.0.0.1:8088
ANALYZER_INTERNAL_TOKEN=
ANALYZER_TIMEOUT_MS=20000
ANALYSIS_POLL_INTERVAL_MS=60000
ANALYSIS_LIGHT_BATCH_SIZE=8
ANALYSIS_IDLE_FREE_MEM_BYTES=6442450944
ANALYSIS_PUBLIC_RECLUSTER_INTERVAL_MINUTES=360
ANALYSIS_PERSONAL_RECLUSTER_INTERVAL_MINUTES=720
